<%- include('partials/head', { title, description, path: canonicalPath, metaRobots }) %>

<div class="max-w-6xl mx-auto px-6 md:px-10 py-12">
  <div class="mb-8">
    <a href="/browse/<%= toolA.category %>" class="text-sm text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors no-underline">
      ← Back to <%= toolA.category.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase()) %>
    </a>
  </div>

  <h1 class="text-5xl md:text-6xl font-bold tracking-tighter text-neutral-900 dark:text-white mb-4">
    <%= toolA.name %> vs <%= toolB.name %>
  </h1>
  <p class="text-lg text-neutral-500 mb-12">
    <span class="font-mono"><%= toolA.category.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase()) %></span>
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
    <!-- Tool A -->
    <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-10 w-10 bg-neutral-200 dark:bg-neutral-700 rounded flex items-center justify-center">
          <span class="font-mono font-bold text-neutral-900 dark:text-white"><%= toolA.name.charAt(0) %></span>
        </div>
        <a href="/tool/<%= toolA.id %>" class="font-semibold text-neutral-900 dark:text-white no-underline"><%= toolA.name %></a>
      </div>
      <% if (comparisonData.priceGap && comparisonData.priceGap.cheaper === 'A') { %>
        <div class="text-xs font-mono text-green-600 dark:text-green-400 mb-3">← More affordable</div>
      <% } %>
      <div class="text-sm text-neutral-500 dark:text-neutral-400 mb-4"><%= toolA.description %></div>
      <div class="text-xs font-mono text-neutral-400 dark:text-neutral-500 mb-1">Switching Cost: <%= toolA.portability.switchingCost %></div>
    </div>

    <!-- Tool B -->
    <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-6">
      <div class="flex items-center gap-3 mb-4">
        <div class="h-10 w-10 bg-neutral-200 dark:bg-neutral-700 rounded flex items-center justify-center">
          <span class="font-mono font-bold text-neutral-900 dark:text-white"><%= toolB.name.charAt(0) %></span>
        </div>
        <a href="/tool/<%= toolB.id %>" class="font-semibold text-neutral-900 dark:text-white no-underline"><%= toolB.name %></a>
      </div>
      <% if (comparisonData.priceGap && comparisonData.priceGap.cheaper === 'B') { %>
        <div class="text-xs font-mono text-green-600 dark:text-green-400 mb-3">← More affordable</div>
      <% } %>
      <div class="text-sm text-neutral-500 dark:text-neutral-400 mb-4"><%= toolB.description %></div>
      <div class="text-xs font-mono text-neutral-400 dark:text-neutral-500 mb-1">Switching Cost: <%= toolB.portability.switchingCost %></div>
    </div>
  </div>

  <!-- Humanized Analysis -->
  <div class="bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-6 mb-8">
    <h2 class="text-xl font-bold text-neutral-900 dark:text-white mb-4">Analysis</h2>
    <% for (const para of humanizedText) { %>
      <p class="text-neutral-700 dark:text-neutral-300 leading-relaxed mb-4"><%= para %></p>
    <% } %>
    
    <div class="mt-6 pt-6 border-t border-neutral-200 dark:border-neutral-800">
      <h3 class="font-semibold text-neutral-900 dark:text-white mb-2">Bottom Line</h3>
      <p class="text-neutral-700 dark:text-neutral-300 leading-relaxed"><%= verdict %></p>
    </div>
  </div>

  <!-- Key Comparison Points -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <% if (comparisonData.priceGap) { %>
    <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5">
      <div class="text-sm font-semibold text-neutral-900 dark:text-white mb-2">Price Difference</div>
      <div class="font-mono text-2xl text-neutral-700 dark:text-neutral-300 mb-2">
        <%= comparisonData.priceGap.ratio.toFixed(1) %>x
      </div>
      <div class="text-xs text-neutral-500 dark:text-neutral-400">
        <%= comparisonData.priceGap.cheaper === 'A' ? toolA.name : toolB.name %> is cheaper by $<%= comparisonData.priceGap.absoluteDiff %>/mo
      </div>
    </div>
    <% } %>

    <% if (comparisonData.freeTierAdvantage) { %>
    <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5">
      <div class="text-sm font-semibold text-neutral-900 dark:text-white mb-2">Free Tier</div>
      <div class="font-mono text-2xl text-neutral-700 dark:text-neutral-300 mb-2">
        <%= comparisonData.freeTierAdvantage === 'A' ? toolA.name : toolB.name %>
      </div>
      <div class="text-xs text-neutral-500 dark:text-neutral-400">
        Has a free tier option
      </div>
    </div>
    <% } %>

    <% if (comparisonData.pricingModelDiffer) { %>
    <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5">
      <div class="text-sm font-semibold text-neutral-900 dark:text-white mb-2">Pricing Model</div>
      <div class="font-mono text-2xl text-neutral-700 dark:text-neutral-300 mb-2">
        Different
      </div>
      <div class="text-xs text-neutral-500 dark:text-neutral-400">
        Tools charge using different pricing philosophies
      </div>
    </div>
    <% } %>

    <% if (comparisonData.switchingCostWinner) { %>
    <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5">
      <div class="text-sm font-semibold text-neutral-900 dark:text-white mb-2">Switching Costs</div>
      <div class="font-mono text-2xl text-neutral-700 dark:text-neutral-300 mb-2">
        <%= comparisonData.switchingCostWinner === 'A' ? toolA.name : toolB.name %>
      </div>
      <div class="text-xs text-neutral-500 dark:text-neutral-400">
        Lower switching costs for easier migration
      </div>
    </div>
    <% } %>
  </div>

  <!-- Related Guides -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-neutral-900 dark:text-white mb-4">Related Guides</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/guides/<%= toolA.id %>-alternatives" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-4 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
        <div class="font-mono text-sm text-neutral-400 dark:text-neutral-600 mb-1">Alternatives</div>
        <div class="font-semibold text-neutral-900 dark:text-white"><%= toolA.name %> Alternatives</div>
      </a>
      <a href="/guides/<%= toolB.id %>-alternatives" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-4 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
        <div class="font-mono text-sm text-neutral-400 dark:text-neutral-600 mb-1">Alternatives</div>
        <div class="font-semibold text-neutral-900 dark:text-white"><%= toolB.name %> Alternatives</div>
      </a>
      <a href="/guides/best-free-<%= toolA.category %>" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-4 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
        <div class="font-mono text-sm text-neutral-400 dark:text-neutral-600 mb-1">Best Free</div>
        <div class="font-semibold text-neutral-900 dark:text-white">Best Free <%= toolA.category.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase()) %></div>
      </a>
    </div>
  </div>
</div>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ComparisonPage",
  "name": title,
  "description": description,
  "url": "https://latest.sh" + (typeof canonicalPath !== 'undefined' ? canonicalPath : path),
  "datePublished": toolA.lastVerified < toolB.lastVerified ? toolA.lastVerified : toolB.lastVerified,
  "dateModified": toolA.lastVerified > toolB.lastVerified ? toolA.lastVerified : toolB.lastVerified,
  "author": {
    "@type": "Organization",
    "name": "Pricing.md"
  },
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "SoftwareApplication",
        "name": toolA.name,
        "url": toolA.url,
        "description": toolA.description,
        "applicationCategory": toolA.category.replace(/-/g, " ")
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "SoftwareApplication",
        "name": toolB.name,
        "url": toolB.url,
        "description": toolB.description,
        "applicationCategory": toolB.category.replace(/-/g, " ")
      }
    }
  ],
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": toolA.name
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": toolB.name
      }
    ]
  }
}, null, 2) %>
</script>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which is cheaper, " + toolA.name + " or " + toolB.name + "?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": comparisonData.priceGap ? (comparisonData.priceGap.cheaper === 'A' ? toolA.name : toolB.name) + " is " + comparisonData.priceGap.ratio.toFixed(1) + "x cheaper than " + (comparisonData.priceGap.cheaper === 'A' ? toolB.name : toolA.name) + ". " + toolA.name + " starts at $" + (toolA.tiers[0]?.basePrice || 0) + "/mo, " + toolB.name + " starts at $" + (toolB.tiers[0]?.basePrice || 0) + "/mo." : "Pricing varies by tier and usage. Check both tools for current rates."
      }
    },
    {
      "@type": "Question",
      "name": "Does " + toolA.name + " have a free tier?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": (toolA.tiers.some(t => t.pricingModel === "free" || t.basePrice === 0) ? "Yes" : "No") + ", " + toolA.name + (toolA.tiers.some(t => t.pricingModel === "free" || t.basePrice === 0) ? " offers a free tier with " + Object.entries(toolA.tiers.find(t => t.pricingModel === "free" || t.basePrice === 0)?.limits || {}).map(([k,v]) => k + ": " + v).join(", ") : " does not have a free tier") + "."
      }
    },
    {
      "@type": "Question",
      "name": "What is the switching cost between " + toolA.name + " and " + toolB.name + "?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": toolA.name + " has " + toolA.portability.switchingCost + " switching cost. " + toolB.name + " has " + toolB.portability.switchingCost + " switching cost. " + (comparisonData.switchingCostWinner ? (comparisonData.switchingCostWinner === 'A' ? toolA.name : toolB.name) + " is easier to switch away from." : "Both have similar switching complexity.")
      }
    }
  ]
}, null, 2) %>
</script>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://latest.sh/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://latest.sh/guides" },
    { "@type": "ListItem", "position": 3, "name": toolA.category.replace(/-/g, " ").replace(/\b\w/g, c => c.toUpperCase()), "item": "https://latest.sh/browse/" + toolA.category },
    { "@type": "ListItem", "position": 4, "name": title, "item": "https://latest.sh" + path }
  ]
}, null, 2) %>
</script>

<%- include('partials/footer') %>
