<%- include('partials/head', { title }) %>

<%
function formatPrice(price) {
  if (price === 0) return '<span class="font-mono text-emerald-600 dark:text-emerald-400">Free</span>';
  if (price === null || price === undefined) return '<span class="font-mono text-neutral-400 italic">Contact Sales</span>';
  return '<span class="font-mono text-neutral-900 dark:text-white">$' + price + '/mo</span>';
}

function switchingBadge(cost) {
  const map = {
    'drop-in': 'border-neutral-300 dark:border-neutral-600 text-neutral-600 dark:text-neutral-400',
    'moderate': 'border-amber-400 dark:border-amber-600 text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-950',
    'significant': 'border-orange-400 dark:border-orange-600 text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-950',
    'architectural': 'border-red-400 dark:border-red-600 text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950',
  };
  return '<span class="inline-block px-2 py-0.5 text-xs font-mono border rounded-none ' + (map[cost] || 'border-neutral-300 dark:border-neutral-700 text-neutral-500') + '">' + cost + '</span>';
}

function freshness(dateStr) {
  const d = new Date(dateStr);
  const now = new Date();
  const days = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24));
  if (days <= 7) return { label: 'Fresh', cls: 'border-neutral-300 dark:border-neutral-600 text-neutral-600 dark:text-neutral-400' };
  if (days <= 30) return { label: 'Recent', cls: 'border-amber-400 dark:border-amber-600 text-amber-600 dark:text-amber-400' };
  return { label: 'Stale', cls: 'border-red-400 dark:border-red-600 text-red-600 dark:text-red-400' };
}

function humanizeKey(key) {
  return key
    .replace(/([A-Z]+)([A-Z][a-z])/g, '$1 $2')
    .replace(/([a-z])([A-Z])/g, '$1 $2')
    .replace(/([a-z])([0-9])/g, '$1 $2')
    .replace(/_/g, ' ')
    .replace(/\b(mb|gb|tb|mau|cpu|ram|api)\b/gi, s => s.toUpperCase())
    .replace(/^./, s => s.toUpperCase())
    .trim();
}

const fresh = freshness(tool.lastVerified);
const categoryDisplay = tool.category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());

function gradeBadgeClass(grade) {
  const map = {
    'A': 'border-emerald-400 dark:border-emerald-600 text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-950',
    'B': 'border-blue-400 dark:border-blue-600 text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-950',
    'C': 'border-amber-400 dark:border-amber-600 text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-950',
    'D': 'border-orange-400 dark:border-orange-600 text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-950',
    'F': 'border-red-400 dark:border-red-600 text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950',
  };
  return map[grade] || 'border-neutral-300 dark:border-neutral-700 text-neutral-500';
}
const hasFree = tool.tiers.some(t => t.pricingModel === 'free' || t.basePrice === 0);
const paidTiers = tool.tiers.filter(t => t.basePrice !== null && t.basePrice > 0);
const lowestPaid = paidTiers.length > 0 ? Math.min(...paidTiers.map(t => t.basePrice)) : null;
%>

<div class="max-w-5xl mx-auto px-6 py-10">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 mb-4 text-sm">
    <a href="/browse" class="text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors font-mono">Browse</a>
    <span class="text-neutral-400">/</span>
    <a href="/browse/<%= tool.category %>" class="text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors font-mono"><%= categoryDisplay %></a>
    <span class="text-neutral-400">/</span>
    <span class="text-neutral-900 dark:text-white font-mono"><%= tool.name %></span>
  </div>

  <!-- Hero -->
  <div class="mb-8">
    <h1 class="text-4xl font-bold tracking-tighter text-neutral-900 dark:text-white"><%= tool.name %></h1>
    <p class="text-neutral-500 mt-2 text-sm max-w-2xl"><%= tool.description %></p>

    <!-- Quick stats row -->
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mt-4">
      <% if (hasFree) { %>
        <span class="text-sm"><span class="text-emerald-600 dark:text-emerald-400 font-mono font-semibold">Free tier</span></span>
      <% } %>
      <% if (lowestPaid !== null) { %>
        <span class="text-sm text-neutral-500">From <span class="font-mono font-semibold text-neutral-900 dark:text-white">$<%= lowestPaid %>/mo</span></span>
      <% } %>
      <span class="text-sm text-neutral-500"><%= tool.tiers.length %> tier<%= tool.tiers.length !== 1 ? 's' : '' %></span>
      <span><%- switchingBadge(tool.portability.switchingCost) %></span>
      <% if (tool.portability.openStandard) { %>
        <span class="text-xs font-mono text-neutral-400"><%= tool.portability.openStandard %></span>
      <% } %>
      <span class="inline-block px-2 py-0.5 text-xs font-mono border rounded-none <%= fresh.cls %>"><%= fresh.label %></span>
      <a href="#transparency-score" class="inline-block px-2 py-0.5 text-xs font-mono font-bold border rounded-none no-underline <%= gradeBadgeClass(transparency.grade) %>">Transparency: <%= transparency.grade %></a>
    </div>

    <div class="flex items-center gap-4 mt-4">
      <a href="<%= tool.pricingUrl %>" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 font-mono text-sm rounded-none border border-neutral-900 dark:border-white hover:opacity-80 transition-opacity no-underline">View Pricing Page &rarr;</a>
      <a href="/tool/<%= tool.id %>/pricing.md" class="inline-flex items-center gap-2 px-4 py-2 font-mono text-sm rounded-none border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all no-underline">View as Markdown</a>
      <span class="text-xs text-neutral-400 font-mono">Verified <%= tool.lastVerified %></span>
    </div>

    <% const toolHasPricingMd = tool.pricingUrl.endsWith('/pricing.md'); %>
    <% if (toolHasPricingMd) { %>
      <div class="flex items-center gap-2 mt-4 px-4 py-3 border border-emerald-300 dark:border-emerald-700 bg-emerald-50 dark:bg-emerald-950">
        <span class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-emerald-500 flex-shrink-0"><svg viewBox="0 0 24 24" width="10" height="10" fill="white"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
        <span class="text-sm text-emerald-700 dark:text-emerald-300"><strong><%= tool.name %></strong> publishes an official <a href="<%= tool.pricingUrl %>" target="_blank" rel="noopener" class="border-b border-emerald-400 hover:border-emerald-700 dark:hover:border-emerald-300 transition-colors">pricing.md</a> file &mdash; machine-readable pricing for AI agents and developer tools.</span>
      </div>
    <% } else { %>
      <div class="mt-4 px-4 py-3 border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-950">
        <div class="flex items-start gap-2">
          <span class="text-amber-500 mt-0.5 flex-shrink-0"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          <div>
            <div class="text-sm text-amber-800 dark:text-amber-200"><strong><%= tool.name %></strong> doesn't publish a pricing.md file yet.</div>
            <div class="text-xs text-amber-600 dark:text-amber-400 mt-1">This pricing data is community-maintained and last verified <%= tool.lastVerified %>.</div>
            <div class="flex items-center gap-3 mt-2">
              <a href="#request-transparency" class="text-xs font-mono text-amber-700 dark:text-amber-300 border-b border-amber-400 hover:border-amber-700 dark:hover:border-amber-300 transition-colors no-underline">Request Transparency &darr;</a>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <!-- Pricing Tiers Table -->
  <div class="bg-white dark:bg-[#111] border border-neutral-300 dark:border-neutral-700 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,0.05)] dark:shadow-[4px_4px_0px_0px_rgba(0,0,0,0.8)] overflow-x-auto theme-transition mb-8">
    <table class="w-full border-collapse">
      <thead>
        <tr class="border-b-2 border-neutral-200 dark:border-neutral-700">
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Tier</th>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Price</th>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Includes</th>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Overage</th>
        </tr>
      </thead>
      <tbody>
        <% for (const tier of tool.tiers) { %>
          <tr class="border-b border-neutral-100 dark:border-neutral-800">
            <!-- Tier name -->
            <td class="px-5 py-4 align-top">
              <div class="font-bold text-neutral-900 dark:text-white"><%= tier.name %></div>
              <div class="text-[10px] font-mono text-neutral-400 uppercase"><%= tier.pricingModel.replace(/_/g, ' ') %></div>
            </td>

            <!-- Price -->
            <td class="px-5 py-4 align-top">
              <div class="text-lg font-mono font-bold">
                <% if (tier.basePrice === 0) { %>
                  <span class="text-emerald-600 dark:text-emerald-400">Free</span>
                <% } else if (tier.basePrice === null) { %>
                  <span class="text-neutral-400 italic text-base">Contact Sales</span>
                <% } else { %>
                  <span class="text-neutral-900 dark:text-white">$<%= tier.basePrice %><span class="text-sm text-neutral-400 font-normal">/mo</span></span>
                <% } %>
              </div>
              <% if (tier.seatPrice !== null) { %>
                <div class="text-xs text-neutral-500 mt-0.5">+ $<%= tier.seatPrice %>/seat</div>
              <% } %>
              <% if (tier.annualDiscount) { %>
                <div class="text-xs text-emerald-500 mt-0.5">-<%= tier.annualDiscount %>% annual</div>
              <% } %>
            </td>

            <!-- Includes (limits + included quantities) -->
            <td class="px-5 py-4 align-top">
              <% const includedMetrics = tier.usageMetrics.filter(m => m.includedQuantity > 0); %>
              <%
                // Skip limit keys that are already represented by an included metric
                // Match by checking if the limit key overlaps with metric name words
                const metricWords = includedMetrics.flatMap(m =>
                  m.name.toLowerCase().replace(/overage/g, '').split(/\s+/).filter(w => w.length > 2)
                );
                const filteredLimits = Object.entries(tier.limits).filter(([key]) => {
                  const k = key.toLowerCase();
                  return !metricWords.some(w => k.includes(w));
                });
              %>
              <% if (filteredLimits.length > 0 || includedMetrics.length > 0) { %>
                <div class="space-y-0.5">
                  <% for (const m of includedMetrics) { %>
                    <div class="text-xs"><span class="text-neutral-500"><%= m.name.replace(/ Overage$/, '') %>:</span> <span class="font-mono text-neutral-900 dark:text-white"><%= m.includedQuantity.toLocaleString() %></span> <span class="text-neutral-400"><%= m.unit %></span></div>
                  <% } %>
                  <% for (const [key, val] of filteredLimits.slice(0, 5)) { %>
                    <div class="text-xs"><span class="text-neutral-500"><%= humanizeKey(key) %>:</span> <span class="font-mono text-neutral-900 dark:text-white"><%= typeof val === 'number' ? val.toLocaleString() : val %></span></div>
                  <% } %>
                  <% if (filteredLimits.length > 5) { %>
                    <div class="text-xs text-neutral-400">+<%= filteredLimits.length - 5 %> more</div>
                  <% } %>
                </div>
              <% } else { %>
                <span class="text-xs text-neutral-400">&mdash;</span>
              <% } %>
            </td>

            <!-- Overage pricing -->
            <td class="px-5 py-4 align-top">
              <% const overageMetrics = tier.usageMetrics.filter(m => m.pricePerUnit > 0); %>
              <% if (overageMetrics.length > 0) { %>
                <div class="space-y-0.5">
                  <% for (const m of overageMetrics) { %>
                    <div class="text-xs"><span class="text-neutral-500"><%= m.name %>:</span> <span class="font-mono text-neutral-900 dark:text-white">$<%= m.pricePerUnit %><% if (m.unitQuantity > 1) { %>/<%= m.unitQuantity.toLocaleString() %><% } %></span> <span class="text-neutral-400">per <%= m.unit %></span></div>
                  <% } %>
                </div>
              <% } else { %>
                <span class="text-xs text-neutral-400">&mdash;</span>
              <% } %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Portability -->
  <% if (tool.portability.whatYouLose) { %>
  <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm mb-8 px-1">
    <div>
      <span class="text-xs font-mono text-neutral-400 uppercase tracking-widest">Switching Cost</span>
      <div class="mt-1"><%- switchingBadge(tool.portability.switchingCost) %></div>
    </div>
    <div>
      <span class="text-xs font-mono text-neutral-400 uppercase tracking-widest">Open Standard</span>
      <div class="mt-1 text-sm <%= tool.portability.openStandard ? 'text-neutral-900 dark:text-white' : 'text-neutral-400' %>"><%= tool.portability.openStandard || 'Proprietary' %></div>
    </div>
    <div class="flex-1 min-w-[250px]">
      <span class="text-xs font-mono text-neutral-400 uppercase tracking-widest">What You Lose</span>
      <div class="mt-1 text-sm text-neutral-500"><%= tool.portability.whatYouLose %></div>
    </div>
  </div>
  <% } %>

  <!-- Request Transparency -->
  <% if (!toolHasPricingMd) { %>
    <div id="request-transparency">
      <%- include('partials/request-transparency') %>
    </div>
  <% } %>

  <!-- Transparency Score -->
  <div id="transparency-score" class="mb-8">
    <div class="text-[10px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-3">Transparency Score</div>
    <div class="bg-white dark:bg-[#111] border border-neutral-300 dark:border-neutral-700 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,0.05)] dark:shadow-[4px_4px_0px_0px_rgba(0,0,0,0.8)] px-5 py-5">
      <div class="flex items-center gap-4 mb-4">
        <span class="text-3xl font-mono font-bold <%= gradeBadgeClass(transparency.grade).split(' ').filter(c => c.startsWith('text-') && !c.startsWith('text-neutral')).join(' ') %>"><%= transparency.grade %></span>
        <div>
          <div class="text-sm font-mono text-neutral-900 dark:text-white"><%= transparency.score %>/100</div>
          <div class="text-xs text-neutral-500">Pricing Transparency Score</div>
        </div>
        <a href="/tool/<%= tool.id %>/badge.svg" target="_blank" class="ml-auto">
          <img src="/tool/<%= tool.id %>/badge.svg" alt="<%= tool.name %> Pricing Transparency: <%= transparency.grade %>" height="20">
        </a>
      </div>

      <!-- Score breakdown -->
      <details class="group">
        <summary class="text-xs font-mono text-neutral-500 cursor-pointer hover:text-neutral-900 dark:hover:text-white transition-colors">Score breakdown</summary>
        <div class="mt-3 space-y-2">
          <% for (const f of transparency.factors) { %>
            <div class="flex items-center justify-between text-xs">
              <div class="flex items-center gap-2">
                <% if (f.earned > 0) { %>
                  <span class="text-emerald-500">&#10003;</span>
                <% } else { %>
                  <span class="text-neutral-300 dark:text-neutral-600">&#10005;</span>
                <% } %>
                <span class="text-neutral-600 dark:text-neutral-400"><%= f.name %></span>
              </div>
              <span class="font-mono text-neutral-500"><%= f.earned %>/<%= f.max %></span>
            </div>
          <% } %>
        </div>
      </details>

    </div>
  </div>

  <!-- Changelog -->
  <% if (changes.length > 0) { %>
    <div class="text-[10px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-3">Pricing Changes</div>
    <div class="bg-white dark:bg-[#111] border border-neutral-300 dark:border-neutral-700 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,0.05)] dark:shadow-[4px_4px_0px_0px_rgba(0,0,0,0.8)] overflow-x-auto theme-transition">
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-neutral-200 dark:border-neutral-800">
            <th class="px-4 py-3 text-left text-[10px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 font-normal">Date</th>
            <th class="px-4 py-3 text-left text-[10px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 font-normal">Type</th>
            <th class="px-4 py-3 text-left text-[10px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 font-normal">Summary</th>
          </tr>
        </thead>
        <tbody>
          <% for (const change of changes) { %>
            <tr class="border-b border-neutral-100 dark:border-neutral-800">
              <td class="px-4 py-3 text-xs text-neutral-400 font-mono whitespace-nowrap"><%= change.detected_at.split('T')[0] %></td>
              <td class="px-4 py-3"><span class="inline-block px-2 py-0.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-500 rounded-none"><%= change.change_type.replace(/_/g, ' ') %></span></td>
              <td class="px-4 py-3 text-sm text-neutral-700 dark:text-neutral-300"><%= change.summary %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%
const prices = tool.tiers.filter(t => t.basePrice !== null).map(t => t.basePrice);
const lowPrice = prices.length > 0 ? Math.min(...prices) : 0;
const highPrice = prices.length > 0 ? Math.max(...prices) : 0;
%>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.name,
  "description": tool.description,
  "url": tool.pricingUrl,
  "applicationCategory": "DeveloperApplication",
  "offers": {
    "@type": "AggregateOffer",
    "lowPrice": String(lowPrice),
    "highPrice": String(highPrice),
    "priceCurrency": "USD",
    "offerCount": String(tool.tiers.length)
  }
}, null, 2) %>
</script>

<%- include('partials/footer') %>
