<%- include('partials/head', { title }) %>

<%
function formatPrice(price) {
  if (price === 0) return '<span class="price price-free">Free</span>';
  if (price === null || price === undefined) return '<span class="price price-contact">Contact Sales</span>';
  return '<span class="price mono">$' + price + '/mo</span>';
}

function switchingBadge(cost) {
  const map = {
    'drop-in': 'badge-green',
    'moderate': 'badge-yellow',
    'significant': 'badge-orange',
    'architectural': 'badge-red',
  };
  return '<span class="badge ' + (map[cost] || 'badge-muted') + '">' + cost + '</span>';
}

function freshness(dateStr) {
  const d = new Date(dateStr);
  const now = new Date();
  const days = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24));
  if (days <= 7) return { label: 'Fresh', cls: 'badge-green' };
  if (days <= 30) return { label: 'Recent', cls: 'badge-yellow' };
  return { label: 'Stale', cls: 'badge-red' };
}

const fresh = freshness(tool.lastVerified);
const categoryDisplay = tool.category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
%>

<div class="container">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 mb-2">
    <a href="/browse" class="text-muted text-sm">Browse</a>
    <span class="text-muted text-sm">/</span>
    <a href="/browse/<%= tool.category %>" class="text-muted text-sm"><%= categoryDisplay %></a>
    <span class="text-muted text-sm">/</span>
    <span class="text-sm"><%= tool.name %></span>
  </div>

  <!-- Hero -->
  <div class="mb-4">
    <div class="flex items-center gap-2 flex-wrap">
      <h1 style="margin-bottom: 0;"><%= tool.name %></h1>
      <span class="badge badge-blue"><%= categoryDisplay %></span>
      <span class="badge <%= fresh.cls %>"><%= fresh.label %></span>
    </div>
    <p class="text-muted mt-1"><%= tool.description %></p>
    <div class="flex items-center gap-3 mt-2">
      <a href="<%= tool.pricingUrl %>" target="_blank" rel="noopener" class="btn">View Pricing Page &rarr;</a>
      <span class="text-xs text-muted">Last verified: <%= tool.lastVerified %></span>
    </div>
  </div>

  <!-- Portability -->
  <div class="card mb-4">
    <h3>Portability</h3>
    <div class="flex items-center gap-3 mt-2 flex-wrap">
      <div>
        <span class="text-xs text-muted">Switching Cost</span><br>
        <%- switchingBadge(tool.portability.switchingCost) %>
      </div>
      <div>
        <span class="text-xs text-muted">Open Standard</span><br>
        <span class="text-sm"><%= tool.portability.openStandard || 'Proprietary' %></span>
      </div>
    </div>
    <p class="text-sm text-muted mt-2"><strong>What you lose:</strong> <%= tool.portability.whatYouLose %></p>
  </div>

  <!-- Tier Cards -->
  <h2 class="mb-2">Pricing Tiers</h2>
  <div class="grid grid-3 mb-4">
    <% for (const tier of tool.tiers) { %>
      <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
          <div>
            <h3 style="margin-bottom: 0.25rem;"><%= tier.name %></h3>
            <span class="badge badge-muted"><%= tier.pricingModel.replace(/_/g, ' ') %></span>
          </div>
          <div style="text-align: right;">
            <%- formatPrice(tier.basePrice) %>
            <% if (tier.billingPeriod) { %>
              <div class="text-xs text-muted"><%= tier.billingPeriod %></div>
            <% } %>
          </div>
        </div>

        <% if (tier.seatPrice !== null) { %>
          <div class="text-sm mt-2">
            <span class="text-muted">Per seat:</span>
            <span class="mono">$<%= tier.seatPrice %>/mo</span>
          </div>
        <% } %>

        <% if (tier.annualDiscount) { %>
          <div class="text-xs text-muted mt-1">
            <%= tier.annualDiscount %>% annual discount
          </div>
        <% } %>

        <% if (tier.usageMetrics.length > 0) { %>
          <div class="mt-3">
            <div class="text-xs text-muted" style="margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Usage Metrics</div>
            <table style="font-size: 0.8125rem;">
              <% for (const m of tier.usageMetrics) { %>
                <tr>
                  <td style="padding: 0.25rem 0.5rem 0.25rem 0; border: none; color: var(--muted);"><%= m.name %></td>
                  <td style="padding: 0.25rem 0; border: none;">
                    <span class="mono"><%= m.includedQuantity.toLocaleString() %></span> <span class="text-muted"><%= m.unit %></span> included
                    <% if (m.pricePerUnit > 0) { %>
                      <br><span class="text-xs text-muted">then $<%= m.pricePerUnit %>/<%= m.unitQuantity > 1 ? m.unitQuantity.toLocaleString() + ' ' : '' %><%= m.unit %></span>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            </table>
          </div>
        <% } %>

        <% const limitEntries = Object.entries(tier.limits); %>
        <% if (limitEntries.length > 0) { %>
          <div class="mt-3">
            <div class="text-xs text-muted" style="margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Limits</div>
            <% for (const [key, val] of limitEntries) { %>
              <div class="text-sm" style="display: flex; justify-content: space-between; padding: 0.125rem 0;">
                <span class="text-muted"><%= key.replace(/([A-Z])/g, ' $1').replace(/^./, s => s.toUpperCase()) %></span>
                <span class="mono"><%= typeof val === 'number' ? val.toLocaleString() : val %></span>
              </div>
            <% } %>
          </div>
        <% } %>

        <% if (tier.features.length > 0) { %>
          <div class="mt-3">
            <div class="text-xs text-muted" style="margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em;">Features</div>
            <% for (const f of tier.features) { %>
              <div class="text-sm" style="padding: 0.125rem 0;">
                <span style="color: <%= f.included ? 'var(--accent)' : 'var(--red)' %>"><%= f.included ? '&#10003;' : '&#10007;' %></span>
                <span class="<%= f.included ? '' : 'text-muted' %>"><%= f.name %></span>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <!-- Changelog -->
  <h2 class="mb-2">Pricing Changes</h2>
  <% if (changes.length > 0) { %>
    <div class="card" style="padding: 0;">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Summary</th>
          </tr>
        </thead>
        <tbody>
          <% for (const change of changes) { %>
            <tr>
              <td class="text-sm text-muted mono"><%= change.detected_at.split('T')[0] %></td>
              <td><span class="badge badge-muted"><%= change.change_type.replace(/_/g, ' ') %></span></td>
              <td class="text-sm"><%= change.summary %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="card">
      <p class="text-muted text-sm">No pricing changes recorded yet. Changes will appear here as <%= tool.name %> updates their pricing.</p>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
