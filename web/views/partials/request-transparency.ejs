<%
const tweetText = encodeURIComponent(
  `Hey${tool.twitterHandle ? ' @' + tool.twitterHandle : ' ' + tool.name}, would you consider publishing a pricing.md file? It makes your pricing machine-readable for AI agents and developer tools.\n\nYour community-maintained pricing data: https://latest.sh/tool/${tool.id}/pricing.md\n\nLearn more: https://github.com/nichochar/pricing.md`
);

const issueTitle = encodeURIComponent(`Add a pricing.md file for machine-readable pricing`);
const issueBody = encodeURIComponent(
  `Hi! I use ${tool.name} and would love to see you publish a pricing.md file.\n\n` +
  `## What is pricing.md?\n\n` +
  `[pricing.md](https://github.com/nichochar/pricing.md) is a standard for publishing machine-readable pricing that AI agents and developer tools can consume directly.\n\n` +
  `## Why?\n\n` +
  `- AI coding agents can automatically factor in your pricing when recommending tools\n` +
  `- Developers get accurate, up-to-date pricing without scraping your website\n` +
  `- You control the data instead of relying on third-party sources\n\n` +
  `## Current state\n\n` +
  `${tool.name}'s pricing data is currently community-maintained at:\n` +
  `https://latest.sh/tool/${tool.id}/pricing.md\n\n` +
  `Publishing an official pricing.md would give you control of that data and improve your visibility in AI-powered tool recommendations.`
);

const emailSubject = encodeURIComponent(`Request: Publish a pricing.md file for ${tool.name}`);
const emailBody = encodeURIComponent(
  `Hi ${tool.name} team,\n\n` +
  `I'm a developer who uses ${tool.name} and I'd love to see you publish a pricing.md file.\n\n` +
  `pricing.md (https://github.com/nichochar/pricing.md) is a standard for machine-readable pricing that AI agents and developer tools can consume directly. ` +
  `Your pricing data is currently community-maintained at https://latest.sh/tool/${tool.id}/pricing.md — publishing an official one would give you control of that data.\n\n` +
  `Thanks!`
);

const shareUrl = encodeURIComponent(`https://latest.sh/tool/${tool.id}?ref=transparency`);
%>

<div class="text-[10px] font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-3">Request Pricing Transparency</div>
<div class="bg-white dark:bg-[#111] border border-neutral-300 dark:border-neutral-700 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,0.05)] dark:shadow-[4px_4px_0px_0px_rgba(0,0,0,0.8)] px-5 py-5 mb-8">
  <div class="flex items-center justify-between mb-4">
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      Help get <strong class="text-neutral-900 dark:text-white"><%= tool.name %></strong> to publish an official
      <a href="https://github.com/nichochar/pricing.md" target="_blank" rel="noopener" class="border-b border-neutral-300 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-white transition-colors">pricing.md</a>
      file. Pick an action:
    </p>
    <div class="flex items-center gap-2 flex-shrink-0 ml-4">
      <button id="vote-btn" onclick="castVote('<%= tool.id %>')"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all cursor-pointer">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 10v12M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2h0a3.13 3.13 0 0 1 3 3.88Z"/></svg>
        +1
      </button>
      <span id="vote-count" class="text-xs font-mono text-neutral-500"><%= typeof voteCount !== 'undefined' && voteCount > 0 ? voteCount + ' developer' + (voteCount !== 1 ? 's' : '') + ' want this' : '' %></span>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <% if (tool.githubOrg) { %>
      <a href="https://github.com/<%= tool.githubOrg %>/<%= tool.id %>/issues/new?title=<%= issueTitle %>&body=<%= issueBody %>" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all no-underline">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Open GitHub Issue
      </a>
    <% } else { %>
      <button onclick="copyToClipboard('github-issue-text')"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all cursor-pointer">
        <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Copy GitHub Issue
      </button>
    <% } %>

    <a href="https://twitter.com/intent/tweet?text=<%= tweetText %>" target="_blank" rel="noopener"
       class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all no-underline">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      Post on X
    </a>

    <a href="mailto:?subject=<%= emailSubject %>&body=<%= emailBody %>"
       class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all no-underline">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      Send Email
    </a>

    <button onclick="copyToClipboard('share-link')"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-900 dark:hover:border-white transition-all cursor-pointer">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      Copy Link
    </button>
  </div>

  <!-- Hidden text for clipboard copy -->
  <textarea id="github-issue-text" class="hidden" aria-hidden="true">Add a pricing.md file for machine-readable pricing

Hi! I use <%= tool.name %> and would love to see you publish a pricing.md file.

## What is pricing.md?

pricing.md (https://github.com/nichochar/pricing.md) is a standard for publishing machine-readable pricing that AI agents and developer tools can consume directly.

## Why?

- AI coding agents can automatically factor in your pricing when recommending tools
- Developers get accurate, up-to-date pricing without scraping your website
- You control the data instead of relying on third-party sources

## Current state

<%= tool.name %>'s pricing data is currently community-maintained at:
https://latest.sh/tool/<%= tool.id %>/pricing.md

Publishing an official pricing.md would give you control of that data.</textarea>
  <input type="hidden" id="share-link" value="https://latest.sh/tool/<%= tool.id %>?ref=transparency">
</div>

<script>
function copyToClipboard(elementId) {
  const el = document.getElementById(elementId);
  const text = el.tagName === 'TEXTAREA' ? el.value : el.value;
  navigator.clipboard.writeText(text).then(() => {
    const btn = event.target.closest('button');
    const original = btn.innerHTML;
    btn.innerHTML = '<svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg> Copied!';
    setTimeout(() => { btn.innerHTML = original; }, 2000);
  });
}

function castVote(toolId) {
  const btn = document.getElementById('vote-btn');
  const countEl = document.getElementById('vote-count');
  btn.disabled = true;
  btn.style.opacity = '0.5';

  fetch('/api/vote/' + toolId, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      if (data.count !== undefined) {
        const c = data.count;
        countEl.textContent = c + ' developer' + (c !== 1 ? 's' : '') + ' want this';
      }
      if (data.error === 'Already voted today') {
        btn.innerHTML = 'Already voted';
      } else {
        btn.innerHTML = 'Voted!';
      }
    })
    .catch(() => {
      btn.disabled = false;
      btn.style.opacity = '1';
    });
}
</script>
