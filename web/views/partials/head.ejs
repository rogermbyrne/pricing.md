<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-GEGJR9CJ3Q"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-GEGJR9CJ3Q');
  </script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Pricing.md</title>
  <meta name="description" content="<%= typeof description !== 'undefined' && description ? description : 'Compare developer tool pricing side-by-side. ' + (typeof toolCount !== 'undefined' ? toolCount : '200+') + ' tools with verified prices, free tier details, and switching costs.' %>">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="canonical" href="https://latest.sh<%= typeof path !== 'undefined' && path ? path : '' %>">
  <meta property="og:title" content="<%= title %> | Pricing.md">
  <meta property="og:description" content="<%= typeof description !== 'undefined' && description ? description : 'Compare developer tool pricing side-by-side. ' + (typeof toolCount !== 'undefined' ? toolCount : '200+') + ' tools with verified prices, free tier details, and switching costs.' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://latest.sh<%= typeof path !== 'undefined' && path ? path : '' %>">
  <meta property="og:image" content="https://latest.sh/og.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="https://latest.sh/og.png">
  <meta name="twitter:title" content="<%= title %> | Pricing.md">
  <meta name="twitter:description" content="<%= typeof description !== 'undefined' && description ? description : 'Compare developer tool pricing side-by-side. ' + (typeof toolCount !== 'undefined' ? toolCount : '200+') + ' tools with verified prices, free tier details, and switching costs.' %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', '-apple-system', 'BlinkMacSystemFont', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
        },
      },
    }
  </script>
  <style>
    body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    .theme-transition {
      transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      transition-duration: 300ms;
    }
  </style>
  <script>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>
</head>
<body class="font-sans bg-white dark:bg-[#09090b] text-neutral-900 dark:text-neutral-100 min-h-screen theme-transition">

  <!-- Sticky nav bar -->
  <nav class="sticky top-0 z-50 backdrop-blur-md bg-white/80 dark:bg-[#09090b]/80 border-b border-neutral-200 dark:border-neutral-800">
    <div class="max-w-6xl mx-auto px-6 md:px-10 h-14 flex items-center justify-between">
      <div class="flex items-center gap-6">
        <a href="/" class="font-mono text-sm font-bold text-neutral-900 dark:text-white no-underline tracking-tight">latest.sh</a>
        <div class="flex items-center gap-5">
          <a href="/browse" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors no-underline">Browse</a>
          <a href="/guides" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors no-underline">Guides</a>
          <a href="/stack" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors no-underline">Advisor</a>
          <a href="/transparency" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors no-underline">Transparency</a>
        </div>
      </div>
      <button id="theme-btn" class="p-2 text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors" aria-label="Toggle Theme" onclick="toggleTheme()">
        <svg id="moon-icon" class="w-4 h-4 hidden dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        <svg id="sun-icon" class="w-4 h-4 block dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
      </button>
    </div>
  </nav>

  <script>
    function toggleTheme() {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    }
  </script>
