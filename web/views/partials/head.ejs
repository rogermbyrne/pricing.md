<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Pricing.md</title>
  <meta name="description" content="Compare developer tool pricing side-by-side. 197 tools with verified prices, free tier details, and switching costs.">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', '-apple-system', 'BlinkMacSystemFont', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
        },
      },
    }
  </script>
  <style>
    body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    .theme-transition {
      transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      transition-duration: 300ms;
    }
  </style>
  <script>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'light') {
        document.documentElement.classList.remove('dark');
      }
    })();
  </script>
</head>
<body class="font-sans bg-white dark:bg-[#0a0a0a] text-neutral-900 dark:text-neutral-100 min-h-screen theme-transition">

  <!-- Dark mode toggle -->
  <button id="themeToggle" onclick="toggleTheme()" class="fixed top-4 right-4 z-50 w-9 h-9 flex items-center justify-center border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-[#111] text-neutral-700 dark:text-neutral-300 hover:border-neutral-900 dark:hover:border-white transition-colors rounded-none">
    <svg id="moonIcon" class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/></svg>
    <svg id="sunIcon" class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5" stroke-width="2"/><path stroke-linecap="round" stroke-width="2" d="M12 1v2m0 18v2m-9-11h2m18 0h2m-3.64-6.36l-1.41 1.41M6.05 17.95l-1.41 1.41m0-13.72l1.41 1.41m11.31 11.31l1.41 1.41"/></svg>
  </button>

  <!-- Nav -->
  <nav class="sticky top-0 z-40 flex items-center justify-between px-6 py-4 border-b border-neutral-200 dark:border-neutral-800 bg-white dark:bg-[#0a0a0a] theme-transition">
    <a href="/" class="font-bold text-lg text-neutral-900 dark:text-neutral-100 tracking-tight hover:no-underline">Pricing<span class="text-neutral-400">.</span>md</a>
    <div class="flex gap-6">
      <a href="/browse" class="font-mono text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors">Browse</a>
      <a href="/compare" class="font-mono text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors">Compare</a>
      <a href="/changelog" class="font-mono text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors">Changelog</a>
    </div>
  </nav>

  <script>
    function toggleTheme() {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    }
  </script>
