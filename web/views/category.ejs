<%- include('partials/head', { title }) %>

<%
function formatPrice(price) {
  if (price === 0) return '<span class="price price-free">Free</span>';
  if (price === null || price === undefined) return '<span class="price price-contact">Contact Sales</span>';
  return '<span class="price mono">$' + price + '/mo</span>';
}

function switchingBadge(cost) {
  const map = {
    'drop-in': 'badge-green',
    'moderate': 'badge-yellow',
    'significant': 'badge-orange',
    'architectural': 'badge-red',
  };
  return '<span class="badge ' + (map[cost] || 'badge-muted') + '">' + cost + '</span>';
}

function modelBadge(model) {
  return '<span class="badge badge-muted">' + model.replace(/_/g, ' ') + '</span>';
}

function hasFree(tool) {
  return tool.tiers.some(t => t.pricingModel === 'free' || t.basePrice === 0);
}

function freeTierInfo(tool) {
  const free = tool.tiers.find(t => t.pricingModel === 'free' || t.basePrice === 0);
  if (!free) return null;
  // Find the most interesting limit
  const limitEntries = Object.entries(free.limits);
  if (limitEntries.length > 0) {
    const [key, val] = limitEntries[0];
    return key.replace(/([A-Z])/g, ' $1').replace(/^./, s => s.toUpperCase()) + ': ' + val.toLocaleString();
  }
  if (free.usageMetrics.length > 0) {
    const m = free.usageMetrics[0];
    return m.includedQuantity.toLocaleString() + ' ' + m.unit;
  }
  return null;
}

function lowestPaid(tool) {
  const paid = tool.tiers.filter(t => t.basePrice !== null && t.basePrice > 0);
  if (paid.length === 0) return null;
  return Math.min(...paid.map(t => t.basePrice));
}

function primaryModel(tool) {
  // Return the most common pricing model across paid tiers
  const paid = tool.tiers.filter(t => t.pricingModel !== 'free');
  if (paid.length === 0) return tool.tiers[0].pricingModel;
  return paid[0].pricingModel;
}
%>

<div class="container-wide">
  <div class="flex items-center gap-2 mb-2">
    <a href="/browse" class="text-muted text-sm">Browse</a>
    <span class="text-muted text-sm">/</span>
    <span class="text-sm"><%= category %></span>
  </div>

  <h1><%= category %></h1>
  <p class="text-muted mb-4"><%= tools.length %> tool<%= tools.length !== 1 ? 's' : '' %> &middot; <a href="/compare?tools=<%= tools.slice(0, 3).map(t => t.id).join(',') %>">Compare top 3</a></p>

  <div class="card" style="overflow-x: auto; padding: 0;">
    <table>
      <thead>
        <tr>
          <th>Tool</th>
          <th>Free Tier</th>
          <th>Lowest Paid</th>
          <th>Model</th>
          <th>Portability</th>
        </tr>
      </thead>
      <tbody>
        <% for (const tool of tools) { %>
          <tr>
            <td>
              <a href="/tool/<%= tool.id %>" style="font-weight: 600;"><%= tool.name %></a>
              <div class="text-xs text-muted mt-1" style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= tool.description %></div>
            </td>
            <td>
              <% if (hasFree(tool)) { %>
                <span class="badge badge-green">Yes</span>
                <% const info = freeTierInfo(tool); %>
                <% if (info) { %>
                  <div class="text-xs text-muted mt-1"><%= info %></div>
                <% } %>
              <% } else { %>
                <span class="badge badge-red">No</span>
              <% } %>
            </td>
            <td>
              <% const lp = lowestPaid(tool); %>
              <%- formatPrice(lp) %>
            </td>
            <td>
              <%- modelBadge(primaryModel(tool)) %>
            </td>
            <td>
              <%- switchingBadge(tool.portability.switchingCost) %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>
