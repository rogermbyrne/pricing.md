<%- include('partials/head', { title }) %>

<%
function formatPrice(price) {
  if (price === 0) return '<span class="font-mono text-neutral-900 dark:text-white">Free</span>';
  if (price === null || price === undefined) return '<span class="font-mono text-neutral-400 italic">Contact Sales</span>';
  return '<span class="font-mono text-neutral-900 dark:text-white">$' + price + '/mo</span>';
}

function switchingBadge(cost) {
  const map = {
    'drop-in': 'border-neutral-300 dark:border-neutral-600 text-neutral-600 dark:text-neutral-400',
    'moderate': 'border-amber-400 dark:border-amber-600 text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-950',
    'significant': 'border-orange-400 dark:border-orange-600 text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-950',
    'architectural': 'border-red-400 dark:border-red-600 text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950',
  };
  return '<span class="inline-block px-2 py-0.5 text-xs font-mono border rounded-none ' + (map[cost] || 'border-neutral-300 dark:border-neutral-700 text-neutral-500') + '">' + cost + '</span>';
}

function modelBadge(model) {
  return '<span class="inline-block px-2 py-0.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-500 rounded-none">' + model.replace(/_/g, ' ') + '</span>';
}

function hasFree(tool) {
  return tool.tiers.some(t => t.pricingModel === 'free' || t.basePrice === 0);
}

function freeTierInfo(tool) {
  const free = tool.tiers.find(t => t.pricingModel === 'free' || t.basePrice === 0);
  if (!free) return null;
  const limitEntries = Object.entries(free.limits);
  if (limitEntries.length > 0) {
    const [key, val] = limitEntries[0];
    return key.replace(/([A-Z])/g, ' $1').replace(/^./, s => s.toUpperCase()) + ': ' + val.toLocaleString();
  }
  if (free.usageMetrics.length > 0) {
    const m = free.usageMetrics[0];
    return m.includedQuantity.toLocaleString() + ' ' + m.unit;
  }
  return null;
}

function lowestPaid(tool) {
  const paid = tool.tiers.filter(t => t.basePrice !== null && t.basePrice > 0);
  if (paid.length === 0) return null;
  return Math.min(...paid.map(t => t.basePrice));
}

function primaryModel(tool) {
  const paid = tool.tiers.filter(t => t.pricingModel !== 'free');
  if (paid.length === 0) return tool.tiers[0].pricingModel;
  return paid[0].pricingModel;
}

function hasPricingMd(tool) {
  return tool.pricingUrl && tool.pricingUrl.endsWith('/pricing.md');
}

function growthCostCell(tool) {
  if (!growthScenario || !growthCosts[tool.id] || growthCosts[tool.id].cost === null) {
    return '<span class="text-neutral-400 font-mono text-sm">&mdash;</span>';
  }
  const cost = growthCosts[tool.id].cost;
  const tier = growthCosts[tool.id].tierName;
  const exceeds = growthCosts[tool.id].exceedsLimits;

  // Entry price: $0 if free tier exists, otherwise lowest paid
  const entryPrice = hasFree(tool) ? 0 : (lowestPaid(tool) || 0);
  const entryStr = entryPrice === 0 ? '$0' : '$' + entryPrice.toLocaleString();
  const scaleStr = '$' + cost.toLocaleString() + '/mo';

  let badge = '';
  if (cheapestGrowthCost && cheapestGrowthCost > 0 && cost > 0) {
    const ratio = cost / cheapestGrowthCost;
    if (ratio > 10) {
      badge = '<span class="inline-block ml-2 px-1.5 py-0.5 text-[10px] font-mono border border-red-400 dark:border-red-600 text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950 rounded-none">' + Math.round(ratio) + 'x</span>';
    } else if (ratio > 5) {
      badge = '<span class="inline-block ml-2 px-1.5 py-0.5 text-[10px] font-mono border border-orange-400 dark:border-orange-600 text-orange-600 dark:text-orange-400 bg-orange-50 dark:bg-orange-950 rounded-none">' + Math.round(ratio) + 'x</span>';
    } else if (ratio > 2) {
      badge = '<span class="inline-block ml-2 px-1.5 py-0.5 text-[10px] font-mono border border-amber-400 dark:border-amber-600 text-amber-600 dark:text-amber-400 bg-amber-50 dark:bg-amber-950 rounded-none">' + Math.round(ratio) + 'x</span>';
    }
  }

  let html = '<span class="text-neutral-400 font-mono text-sm">' + entryStr + '</span>';
  html += '<span class="text-neutral-500 mx-1">&rarr;</span>';
  html += '<span class="font-mono font-semibold text-neutral-900 dark:text-white">' + scaleStr + '</span>' + badge;
  if (tier) {
    html += '<div class="text-[11px] text-neutral-400 mt-0.5">' + tier + (exceeds ? ' (limits exceeded)' : '') + '</div>';
  }
  return html;
}
%>

<div class="max-w-7xl mx-auto px-6 py-10">
  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 mb-4 text-sm">
    <a href="/browse" class="text-neutral-500 hover:text-neutral-900 dark:hover:text-white transition-colors font-mono">Browse</a>
    <span class="text-neutral-400">/</span>
    <span class="text-neutral-900 dark:text-white font-mono"><%= category %></span>
  </div>

  <h1 class="text-4xl font-bold tracking-tighter text-neutral-900 dark:text-white"><%= category %></h1>
  <p class="text-base text-neutral-500 mt-2"><%= tools.length %> tool<%= tools.length !== 1 ? 's' : '' %> &middot; <a href="/compare?tools=<%= tools.slice(0, 3).map(t => t.id).join(',') %>" class="text-neutral-400 hover:text-neutral-900 dark:hover:text-white border-b border-neutral-300 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-white pb-0.5 transition-all">Compare top 3</a></p>

  <div class="flex items-center gap-2 mt-4 text-xs text-neutral-400 dark:text-neutral-500">
    <span class="inline-flex items-center justify-center w-3.5 h-3.5 rounded-full bg-[#1d9bf0] flex-shrink-0"><svg viewBox="0 0 24 24" width="8" height="8" fill="white"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
    <span>= publishes a <a href="https://github.com/nichochar/pricing.md" class="text-neutral-500 hover:text-neutral-900 dark:hover:text-white border-b border-neutral-300 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-white transition-all">pricing.md</a> file &mdash; machine-readable pricing your AI agent can use directly</span>
  </div>

  <div class="flex flex-wrap items-center gap-3 mt-6 mb-8">
    <span class="text-neutral-400 font-mono text-xs uppercase tracking-widest">Sort:</span>
    <a href="/browse/<%= categorySlug %>?sort=name" class="px-3 py-1.5 text-xs font-mono uppercase tracking-widest rounded-full transition-all <%= currentSort === 'name' ? 'bg-neutral-900 dark:bg-white text-white dark:text-neutral-900' : 'text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700' %>">Name</a>
    <a href="/browse/<%= categorySlug %>?sort=lowest-paid" class="px-3 py-1.5 text-xs font-mono uppercase tracking-widest rounded-full transition-all <%= currentSort === 'lowest-paid' ? 'bg-neutral-900 dark:bg-white text-white dark:text-neutral-900' : 'text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700' %>">Lowest Paid</a>
    <a href="/browse/<%= categorySlug %>?sort=free-first" class="px-3 py-1.5 text-xs font-mono uppercase tracking-widest rounded-full transition-all <%= currentSort === 'free-first' ? 'bg-neutral-900 dark:bg-white text-white dark:text-neutral-900' : 'text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700' %>">Free First</a>
    <a href="/browse/<%= categorySlug %>?sort=verified" class="px-3 py-1.5 text-xs font-mono uppercase tracking-widest rounded-full transition-all <%= currentSort === 'verified' ? 'bg-neutral-900 dark:bg-white text-white dark:text-neutral-900' : 'text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700' %>">Verified</a>
    <% if (growthScenario) { %>
    <a href="/browse/<%= categorySlug %>?sort=growth-cost" class="px-3 py-1.5 text-xs font-mono uppercase tracking-widest rounded-full transition-all <%= currentSort === 'growth-cost' ? 'bg-neutral-900 dark:bg-white text-white dark:text-neutral-900' : 'text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700' %>">Growth Cost</a>
    <% } %>
    <a href="/browse/<%= categorySlug %>?sort=transparency" class="px-3 py-1.5 text-xs font-mono uppercase tracking-widest rounded-full transition-all <%= currentSort === 'transparency' ? 'bg-neutral-900 dark:bg-white text-white dark:text-neutral-900' : 'text-neutral-400 hover:text-neutral-900 dark:hover:text-white bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700' %>">Transparency</a>
  </div>

  <div class="bg-white dark:bg-[#111] border border-neutral-300 dark:border-neutral-700 rounded-none shadow-[4px_4px_0px_0px_rgba(0,0,0,0.05)] dark:shadow-[4px_4px_0px_0px_rgba(0,0,0,0.8)] overflow-x-auto theme-transition">
    <table class="w-full border-collapse">
      <thead>
        <tr class="border-b border-neutral-200 dark:border-neutral-800">
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Tool</th>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Free Tier</th>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Lowest Paid</th>
          <% if (growthScenario) { %>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">
            Cost at Scale
            <div class="font-normal normal-case tracking-normal text-[10px] text-neutral-400 mt-0.5">at <%= growthScenario.label %></div>
          </th>
          <% } %>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Model</th>
          <th class="px-5 py-3 text-left text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Portability</th>
          <th class="px-5 py-3 text-center text-xs font-mono uppercase tracking-widest text-neutral-500 font-normal">Score</th>
        </tr>
      </thead>
      <tbody>
        <% for (const tool of tools) { %>
          <tr class="border-b border-neutral-100 dark:border-neutral-800 hover:bg-neutral-50 dark:hover:bg-[#0a0a0a] transition-colors">
            <td class="px-5 py-4">
              <div class="flex items-center gap-1.5">
                <a href="/tool/<%= tool.id %>" class="font-bold text-base text-neutral-900 dark:text-white hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors no-underline"><%= tool.name %></a>
                <% if (hasPricingMd(tool)) { %>
                  <span title="Publishes a pricing.md file — machine-readable pricing for AI agents" class="inline-flex items-center justify-center w-4 h-4 rounded-full bg-[#1d9bf0] flex-shrink-0 cursor-help"><svg viewBox="0 0 24 24" width="10" height="10" fill="white"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg></span>
                <% } %>
                <a href="/tool/<%= tool.id %>/pricing.md" title="View pricing as markdown" class="text-[10px] font-mono text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors no-underline border-b border-neutral-200 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-white">md</a>
              </div>
              <div class="text-sm text-neutral-500 mt-0.5 max-w-[300px] truncate"><%= tool.description %></div>
            </td>
            <td class="px-5 py-4">
              <% if (hasFree(tool)) { %>
                <span class="inline-block px-2 py-0.5 text-xs font-mono border border-neutral-300 dark:border-neutral-600 text-neutral-600 dark:text-neutral-400 rounded-none">Yes</span>
                <% const info = freeTierInfo(tool); %>
                <% if (info) { %>
                  <div class="text-xs text-neutral-400 dark:text-neutral-600 mt-0.5"><%= info %></div>
                <% } %>
              <% } else { %>
                <span class="inline-block px-2 py-0.5 text-xs font-mono border border-neutral-300 dark:border-neutral-700 text-neutral-400 rounded-none">No</span>
              <% } %>
            </td>
            <td class="px-5 py-4">
              <% const lp = lowestPaid(tool); %>
              <%- formatPrice(lp) %>
            </td>
            <% if (growthScenario) { %>
            <td class="px-5 py-4">
              <%- growthCostCell(tool) %>
            </td>
            <% } %>
            <td class="px-5 py-4">
              <%- modelBadge(primaryModel(tool)) %>
            </td>
            <td class="px-5 py-4">
              <%- switchingBadge(tool.portability.switchingCost) %>
            </td>
            <td class="px-5 py-4 text-center">
              <%
                const ts = transparencyScores[tool.id];
                const gradeColorMap = { A: 'text-emerald-600 dark:text-emerald-400', B: 'text-blue-600 dark:text-blue-400', C: 'text-amber-600 dark:text-amber-400', D: 'text-orange-600 dark:text-orange-400', F: 'text-red-600 dark:text-red-400' };
              %>
              <a href="/tool/<%= tool.id %>#transparency-score" class="font-mono font-bold text-sm no-underline <%= gradeColorMap[ts.grade] || 'text-neutral-500' %>"><%= ts.grade %></a>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>
