<%- include('partials/head', { title, description, path }) %>

<div class="max-w-6xl mx-auto px-6 md:px-10 py-12">
  <div class="mb-8">
    <a href="/browse/<%= tool.category %>" class="text-sm text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors no-underline">
      ← Back to <%= categoryDisplayName %>
    </a>
  </div>

  <h1 class="text-5xl md:text-6xl font-bold tracking-tighter text-neutral-900 dark:text-white mb-4">
    <%= tool.name %> Alternatives
  </h1>
  <p class="text-lg text-neutral-500 mb-6">
    <span class="font-mono"><%= alternatives.length %></span> alternatives in <%= categoryDisplayName %>
  </p>
  <p class="text-neutral-700 dark:text-neutral-300 mb-12 max-w-3xl"><%= tool.description %></p>

  <!-- Tool Card -->
  <div class="bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-6 mb-8">
    <a href="/tool/<%= tool.id %>" class="block no-underline">
      <div class="flex items-center gap-3 mb-3">
        <div class="h-10 w-10 bg-neutral-200 dark:bg-neutral-700 rounded flex items-center justify-center">
          <span class="font-mono font-bold text-neutral-900 dark:text-white"><%= tool.name.charAt(0) %></span>
        </div>
        <div>
          <div class="font-semibold text-neutral-900 dark:text-white"><%= tool.name %></div>
          <div class="text-xs font-mono text-neutral-400 dark:text-neutral-600"><%= tool.category.replace(/-/g, " ") %></div>
        </div>
      </div>
      <div class="text-sm text-neutral-500 dark:text-neutral-400">
        <%= tool.description %>
      </div>
    </a>
  </div>

  <!-- Alternatives Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
    <% for (const alt of alternatives) { %>
      <a href="/tool/<%= alt.id %>" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
        <div class="flex items-center gap-3 mb-3">
          <div class="h-10 w-10 bg-neutral-200 dark:bg-neutral-700 rounded flex items-center justify-center">
            <span class="font-mono font-bold text-neutral-900 dark:text-white"><%= alt.name.charAt(0) %></span>
          </div>
          <div>
            <div class="font-semibold text-neutral-900 dark:text-white"><%= alt.name %></div>
            <div class="text-xs font-mono text-neutral-400 dark:text-neutral-600"><%= alt.portability.switchingCost %> switch cost</div>
          </div>
        </div>
        <div class="text-sm text-neutral-500 dark:text-neutral-400 mb-3"><%= alt.description %></div>
        <% if (alt.tiers.some(t => t.pricingModel === 'free' || t.basePrice === 0)) { %>
          <div class="text-xs font-mono text-green-600 dark:text-green-400">Has free tier</div>
        <% } %>
      </a>
    <% } %>
  </div>

  <!-- Related Guides -->
  <div class="mb-8">
    <h2 class="text-xl font-bold text-neutral-900 dark:text-white mb-4">Related Guides</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <a href="/guides/best-free-<%= tool.category %>" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-4 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
        <div class="font-mono text-sm text-neutral-400 dark:text-neutral-600 mb-1">Best Free</div>
        <div class="font-semibold text-neutral-900 dark:text-white">Best Free <%= categoryDisplayName %></div>
      </a>
      <a href="/browse/<%= tool.category %>" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-4 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
        <div class="font-mono text-sm text-neutral-400 dark:text-neutral-600 mb-1">Category</div>
        <div class="font-semibold text-neutral-900 dark:text-white">Browse <%= categoryDisplayName %></div>
      </a>
    </div>
  </div>
</div>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": title,
  "description": description,
  "numberOfItems": alternatives.length,
  "itemListElement": alternatives.map((alt, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": alt.name,
    "url": "https://latest.sh/tool/" + alt.id
  })),
  "about": {
    "@type": "SoftwareApplication",
    "name": tool.name,
    "url": tool.url
  }
}, null, 2) %>
</script>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://latest.sh/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://latest.sh/guides" },
    { "@type": "ListItem", "position": 3, "name": categoryDisplayName, "item": "https://latest.sh/browse/" + tool.category },
    { "@type": "ListItem", "position": 4, "name": tool.name, "item": "https://latest.sh/tool/" + tool.id },
    { "@type": "ListItem", "position": 5, "name": "Alternatives", "item": "https://latest.sh" + path }
  ]
}, null, 2) %>
</script>

<%- include('partials/footer') %>
