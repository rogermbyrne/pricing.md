<%- include('partials/head', { title: 'Stack Advisor', description: 'Describe your app and get a recommended developer tool stack with real pricing at different user scales.', path: '/stack' }) %>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .drawer-content h2 { font-size: 1.25rem; font-weight: 700; margin-top: 2.5rem; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid; }
  .drawer-content h2:first-child { margin-top: 0; }
  .drawer-content h3 { font-size: 1.05rem; font-weight: 700; margin-top: 1.75rem; margin-bottom: 0.5rem; }
  .drawer-content p { margin-top: 0.5rem; line-height: 1.7; }
  .drawer-content ul { margin: 0.75rem 0; padding-left: 1.25rem; }
  .drawer-content li { margin: 0.35rem 0; line-height: 1.6; }
  .drawer-content table { margin: 0.5rem 0; }
  .drawer-content tr:nth-child(even) td { background: rgba(0,0,0,0.02); }
  .drawer-content td:last-child { text-align: right; font-weight: 600; }
  .dark .drawer-content h2 { border-color: #333; color: #fff; }
  .dark .drawer-content h3 { color: #fff; }
  .dark .drawer-content tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
</style>

<!-- Drawer overlay -->
<div id="drawer-overlay" class="fixed inset-0 bg-black/30 backdrop-blur-sm z-40 hidden transition-opacity duration-300 opacity-0" onclick="closeDrawer()"></div>

<!-- Artifact drawer -->
<div id="drawer" class="fixed top-0 right-0 h-full bg-white dark:bg-[#0a0a0a] border-l border-neutral-200 dark:border-neutral-800 z-50 transform translate-x-full transition-transform duration-300 ease-out flex flex-col" style="width: 55vw; min-width: 400px; max-width: 90vw;">
  <!-- Resize handle -->
  <div id="drawer-resize" class="absolute top-0 left-0 w-1.5 h-full cursor-col-resize z-20 hover:bg-neutral-400/30 active:bg-neutral-400/40 transition-colors" style="touch-action:none"></div>
  <div class="sticky top-0 bg-white dark:bg-[#0a0a0a] border-b border-neutral-200 dark:border-neutral-800 px-6 py-4 flex justify-between items-center z-10">
    <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-400">Stack Recommendation</span>
    <button onclick="closeDrawer()" class="text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors text-lg leading-none">&times;</button>
  </div>
  <div id="drawer-content" class="drawer-content flex-1 overflow-y-auto px-6 py-6 text-neutral-700 dark:text-neutral-300 text-sm"></div>
</div>

<div class="max-w-4xl mx-auto px-6 py-10 flex flex-col" style="min-height:calc(100vh - 80px)">

  <!-- Header -->
  <div class="mb-10 text-center">
    <h1 class="text-4xl font-bold tracking-tighter text-neutral-900 dark:text-white">Stack Advisor</h1>
    <p class="text-base text-neutral-500 mt-2">Describe your app. Get a recommended stack with real pricing.</p>
  </div>

  <!-- Chat messages area -->
  <div id="messages" class="flex-1 overflow-y-auto space-y-6 mb-6">
    <% if (typeof hasApiKey !== 'undefined' && !hasApiKey) { %>
    <div class="text-center py-8">
      <p class="text-neutral-500">Stack Advisor requires an API key. Set <code class="font-mono text-sm bg-neutral-100 dark:bg-neutral-800 px-1.5 py-0.5 rounded">ANTHROPIC_API_KEY</code> to enable.</p>
    </div>
    <% } else { %>
    <!-- Welcome -->
    <div class="max-w-2xl mx-auto">
      <p class="text-neutral-500 text-center mb-6">Tell me about your app and I'll recommend a dev tool stack with real pricing at different user scales, migration paths, and open-source options.</p>
      <div class="flex flex-wrap justify-center gap-2" id="examples-container">
        <button onclick="useExample(this)" data-prompt="I'm building a waitlist and launch page tool for indie hackers. Need auth, a database for signups, transactional emails, and basic analytics. Starting solo, hoping to get to 1,000 paying users." class="px-4 py-2 text-sm text-neutral-500 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-neutral-900 dark:hover:text-white rounded-full transition-all cursor-pointer">Waitlist tool for indie hackers</button>
        <button onclick="useExample(this)" data-prompt="I want to build a simple invoicing SaaS for freelancers. Need auth, a database, PDF generation, payment processing with Stripe, and email notifications. Targeting maybe 500 users to start." class="px-4 py-2 text-sm text-neutral-500 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-neutral-900 dark:hover:text-white rounded-full transition-all cursor-pointer">Invoicing SaaS for freelancers</button>
        <button onclick="useExample(this)" data-prompt="I'm building a team feedback and retro tool, like a lightweight Lattice. Need auth, a Postgres database, real-time updates, email digests, and hosting. Small teams, maybe 50 companies with 10-20 users each." class="px-4 py-2 text-sm text-neutral-500 dark:text-neutral-400 bg-neutral-100 dark:bg-neutral-800 hover:bg-neutral-200 dark:hover:bg-neutral-700 hover:text-neutral-900 dark:hover:text-white rounded-full transition-all cursor-pointer">Team retro tool for small teams</button>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Input area -->
  <% if (typeof hasApiKey === 'undefined' || hasApiKey) { %>
  <div class="sticky bottom-0 bg-gradient-to-t from-white dark:from-[#0a0a0a] from-80% to-transparent pt-6 pb-8">
    <div class="max-w-2xl mx-auto flex gap-3">
      <input id="chatInput" type="text" placeholder="Describe your app..."
        class="flex-1 bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 text-neutral-900 dark:text-white px-5 py-3.5 font-sans text-base rounded-full focus:outline-none focus:border-neutral-400 dark:focus:border-neutral-500 transition-colors"
        onkeydown="if(event.key==='Enter')sendMessage()">
      <button onclick="sendMessage()" id="sendBtn"
        class="px-5 py-3.5 bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 font-mono text-sm rounded-full hover:opacity-80 transition-opacity">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </button>
    </div>
  </div>
  <% } %>
</div>

<script>
  var messagesDiv = document.getElementById('messages');
  var chatInput = document.getElementById('chatInput');
  var sendBtn = document.getElementById('sendBtn');
  var chatHistory = [];
  var isLoading = false;

  function useExample(btn) {
    if (!chatInput || isLoading) return;
    chatInput.value = btn.dataset.prompt || btn.textContent.trim();
    sendMessage();
  }

  function addMessage(role, content, rawMarkdown) {
    var div = document.createElement('div');
    if (role === 'user') {
      div.className = 'flex justify-end';
      div.innerHTML = '<div class="bg-neutral-100 dark:bg-neutral-800 text-neutral-900 dark:text-white px-5 py-3 max-w-[75%] text-base rounded-2xl">' + escapeHtml(content) + '</div>';
    } else {
      // Result card
      var preview = getPreview(rawMarkdown || content);
      var rendered = renderMarkdown(rawMarkdown || content);
      div.className = 'max-w-2xl';
      div.innerHTML =
        '<div class="result-card cursor-pointer rounded-lg border border-neutral-200 dark:border-neutral-700 p-5 hover:border-neutral-400 dark:hover:border-neutral-500 hover:shadow-md transition-all" onclick="openDrawer(this)">' +
          '<div class="font-mono text-[10px] uppercase tracking-widest text-neutral-400 mb-2">Pricing.md</div>' +
          '<div class="font-bold text-base text-neutral-900 dark:text-white mb-1">Stack Recommendation</div>' +
          '<div class="text-sm text-neutral-500 line-clamp-2">' + escapeHtml(preview) + '</div>' +
          '<div class="mt-3 flex items-center gap-1 text-xs text-neutral-400 font-mono">View details <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg></div>' +
        '</div>';
      // Store rendered content for the drawer
      div.querySelector('.result-card').dataset.content = rendered;
    }
    messagesDiv.appendChild(div);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
  }

  function getPreview(markdown) {
    // Strip markdown formatting for preview
    var text = markdown
      .replace(/#{1,3}\s+/g, '')
      .replace(/\*\*(.+?)\*\*/g, '$1')
      .replace(/\|[^\n]+/g, '')
      .replace(/[-]{3,}/g, '')
      .replace(/`([^`]+)`/g, '$1')
      .replace(/\n+/g, ' ')
      .trim();
    if (text.length > 140) text = text.substring(0, 140).replace(/\s\S*$/, '') + '...';
    return text;
  }

  function openDrawer(card) {
    var content = card.dataset.content;
    var drawerContent = document.getElementById('drawer-content');
    drawerContent.innerHTML = content;
    // Show drawer
    document.getElementById('drawer').classList.remove('translate-x-full');
    var overlay = document.getElementById('drawer-overlay');
    overlay.classList.remove('hidden');
    setTimeout(function() { overlay.classList.remove('opacity-0'); overlay.classList.add('opacity-100'); }, 10);
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    document.getElementById('drawer').classList.add('translate-x-full');
    var overlay = document.getElementById('drawer-overlay');
    overlay.classList.remove('opacity-100');
    overlay.classList.add('opacity-0');
    setTimeout(function() { overlay.classList.add('hidden'); }, 300);
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDrawer(); });

  function addThinkingIndicator() {
    removeThinkingIndicator();
    var div = document.createElement('div');
    div.id = 'thinking-indicator';
    div.className = 'flex items-center gap-3 py-3';
    div.innerHTML = '<div class="flex gap-1"><span class="w-2 h-2 bg-neutral-400 dark:bg-neutral-500 rounded-full animate-bounce" style="animation-delay:0ms"></span><span class="w-2 h-2 bg-neutral-400 dark:bg-neutral-500 rounded-full animate-bounce" style="animation-delay:150ms"></span><span class="w-2 h-2 bg-neutral-400 dark:bg-neutral-500 rounded-full animate-bounce" style="animation-delay:300ms"></span></div><span class="text-xs text-neutral-400 font-mono">Analyzing your stack needs...</span>';
    messagesDiv.appendChild(div);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
  }

  function removeThinkingIndicator() {
    var el = document.getElementById('thinking-indicator');
    if (el) el.remove();
  }

  function addToolCallIndicator(toolName) {
    removeThinkingIndicator();
    var existing = document.getElementById('tool-indicator');
    var label = toolName === 'find_cheapest' ? 'cheapest options' : toolName === 'get_oss_alternatives' ? 'open-source alternatives' : 'pricing data';
    if (existing) {
      existing.querySelector('span:last-child').textContent = 'Looking up ' + label + '...';
      return;
    }
    var div = document.createElement('div');
    div.id = 'tool-indicator';
    div.className = 'text-xs font-mono text-neutral-400 flex items-center gap-2 py-2';
    div.innerHTML = '<span class="inline-block w-2 h-2 bg-neutral-400 rounded-full animate-pulse"></span><span>Looking up ' + label + '...</span>';
    messagesDiv.appendChild(div);
    messagesDiv.scrollTop = messagesDiv.scrollHeight;
  }

  function removeToolIndicators() {
    var el = document.getElementById('tool-indicator');
    if (el) el.remove();
  }

  function escapeHtml(text) {
    var d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }

  function renderMarkdown(text) {
    // Pre-process: the model sometimes outputs entire tables on one line.
    // Insert newlines before separator patterns (|---|) and after them.
    text = text.replace(/\|\s*(\|[\s:-]+(?:\|[\s:-]+)+\|)\s*\|/g, '|\n$1\n|');
    // Also insert newlines between row-ending "| |" patterns where the next cell has content
    // This handles "| $0 | | Auth |" → newline before "| Auth |"
    // Use a lookahead: split when "|" is followed by " |" then a word char
    text = text.replace(/\|\s+\|(?=\s*[A-Za-z*$#])/g, '|\n|');

    // Parse tables first (line-by-line for robustness), then inline formatting
    var lines = text.split('\n');
    var out = [];
    var i = 0;

    function isSeparatorLine(line) {
      var t = line.trim();
      // Match separator lines like |---|---|, |:---:|, | --- | --- |, etc.
      return /\|/.test(t) && /^[\s|:_-]+$/.test(t) && /--/.test(t);
    }

    function isTableRow(line) {
      var t = line.trim();
      return t.indexOf('|') >= 0 && t.split('|').filter(Boolean).length >= 2;
    }

    function parseRow(line) {
      return line.split('|').map(function(c) { return c.trim(); }).filter(Boolean);
    }

    while (i < lines.length) {
      // Detect table: current line has |, next line is a separator
      if (isTableRow(lines[i]) && i + 1 < lines.length && isSeparatorLine(lines[i + 1])) {
        var headerCells = parseRow(lines[i]);
        i += 2; // skip header + separator
        var rows = [];
        while (i < lines.length && isTableRow(lines[i]) && !isSeparatorLine(lines[i])) {
          rows.push(parseRow(lines[i]));
          i++;
        }
        var table = '<div class="overflow-x-auto my-4"><table class="w-full text-sm border-collapse">';
        table += '<thead><tr class="border-b-2 border-neutral-200 dark:border-neutral-700">';
        headerCells.forEach(function(h) { table += '<th class="px-3 py-2.5 text-left text-xs font-mono uppercase tracking-widest text-neutral-500">' + h + '</th>'; });
        table += '</tr></thead><tbody>';
        rows.forEach(function(row) {
          table += '<tr class="border-b border-neutral-100 dark:border-neutral-800">';
          row.forEach(function(cell) { table += '<td class="px-3 py-2.5 text-neutral-700 dark:text-neutral-300">' + cell + '</td>'; });
          table += '</tr>';
        });
        table += '</tbody></table></div>';
        out.push(table);
      } else {
        out.push(lines[i]);
        i++;
      }
    }

    var html = out.join('\n');
    // Clean up orphaned pipe fragments from inline table splitting
    // e.g. "| $44-59/month |" on its own line → just show the content
    html = html.replace(/^\s*\|\s*([^|]+?)\s*\|\s*$/gm, function(match, content) {
      content = content.trim();
      if (!content) return ''; // empty pipe line, remove
      return content; // show content without pipes
    });
    // Remove blank lines that are just whitespace
    html = html.replace(/\n{3,}/g, '\n\n');
    // Bold
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    // Headers
    html = html.replace(/^### (.+)$/gm, '<h3 class="text-base font-bold text-neutral-900 dark:text-white mt-5 mb-2">$1</h3>');
    html = html.replace(/^## (.+)$/gm, '<h2 class="text-lg font-bold text-neutral-900 dark:text-white mt-7 mb-3 pb-2 border-b border-neutral-200 dark:border-neutral-700">$1</h2>');
    // Horizontal rules
    html = html.replace(/^---$/gm, '<hr class="border-neutral-200 dark:border-neutral-700 my-4">');
    // Bullet lists
    html = html.replace(/^- (.+)$/gm, '<li class="text-sm text-neutral-600 dark:text-neutral-400">$1</li>');
    html = html.replace(/(<li[^>]*>.*<\/li>\n?)+/g, '<ul class="my-2 list-disc pl-5">$&</ul>');
    // Code inline
    html = html.replace(/`([^`]+)`/g, '<code class="font-mono text-sm bg-neutral-100 dark:bg-neutral-800 px-1.5 py-0.5 rounded text-neutral-800 dark:text-neutral-200">$1</code>');
    // Money formatting — only highlight non-zero amounts
    html = html.replace(/\$([1-9][0-9,.]*)(\/mo)?/g, '<span class="font-mono font-semibold text-neutral-900 dark:text-white">$$$1$2</span>');
    // Paragraphs
    html = html.replace(/\n\n/g, '</p><p class="text-sm text-neutral-600 dark:text-neutral-400 mt-3 leading-relaxed">');
    html = '<p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">' + html + '</p>';
    return html;
  }

  async function sendMessage() {
    if (isLoading) return;
    var msg = chatInput.value.trim();
    if (!msg) return;

    chatInput.value = '';
    // Hide welcome/examples on first message
    var welcomeEl = document.querySelector('#messages > .max-w-2xl');
    if (welcomeEl) welcomeEl.remove();
    addMessage('user', msg);
    chatHistory.push({ role: 'user', content: msg });
    addThinkingIndicator();

    isLoading = true;
    sendBtn.style.opacity = '0.5';
    sendBtn.style.pointerEvents = 'none';

    try {
      var response = await fetch('/api/stack', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, history: chatHistory.slice(-10) })
      });

      if (!response.ok) {
        console.error('Stack Advisor API error:', response.status, response.statusText);
        removeThinkingIndicator();
        var errMsg = response.status === 429 ? 'Rate limit reached. Please try again in a few minutes.'
          : response.status === 503 ? 'Stack Advisor is not available right now.'
          : 'Something went wrong (HTTP ' + response.status + '). Please try again.';
        addMessage('assistant', errMsg, errMsg);
        return;
      }

      var reader = response.body.getReader();
      var decoder = new TextDecoder();
      var buffer = '';
      var fullResponse = '';

      while (true) {
        var result = await reader.read();
        if (result.done) break;

        buffer += decoder.decode(result.value, { stream: true });
        var lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (var i = 0; i < lines.length; i++) {
          var line = lines[i];
          if (!line.startsWith('data: ')) continue;
          var data = line.slice(6);
          if (data === '[DONE]') continue;

          try {
            var parsed = JSON.parse(data);
            if (parsed.type === 'tool_call') {
              addToolCallIndicator(parsed.name);
            } else if (parsed.type === 'text') {
              removeToolIndicators();
              fullResponse = parsed.content;
            } else if (parsed.type === 'error') {
              addMessage('assistant', 'Sorry, something went wrong. Please try again.', 'Error occurred.');
            }
          } catch (e) { /* ignore parse errors */ }
        }
      }

      removeThinkingIndicator();
      removeToolIndicators();
      if (fullResponse) {
        addMessage('assistant', fullResponse, fullResponse);
        chatHistory.push({ role: 'assistant', content: fullResponse });
        // Auto-open the drawer with the latest result
        var cards = document.querySelectorAll('.result-card');
        if (cards.length > 0) openDrawer(cards[cards.length - 1]);
      }
    } catch (err) {
      console.error('Stack Advisor fetch error:', err);
      removeThinkingIndicator();
      removeToolIndicators();
      addMessage('assistant', 'Connection error. Please try again.', 'Connection error.');
    } finally {
      isLoading = false;
      sendBtn.style.opacity = '1';
      sendBtn.style.pointerEvents = 'auto';
      chatInput.focus();
    }
  }

  // --- Drawer resize ---
  (function() {
    var handle = document.getElementById('drawer-resize');
    var drawer = document.getElementById('drawer');
    var dragging = false;
    handle.addEventListener('mousedown', function(e) {
      e.preventDefault();
      dragging = true;
      drawer.style.transition = 'none';
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
    });
    document.addEventListener('mousemove', function(e) {
      if (!dragging) return;
      var newWidth = window.innerWidth - e.clientX;
      if (newWidth < 400) newWidth = 400;
      if (newWidth > window.innerWidth * 0.9) newWidth = window.innerWidth * 0.9;
      drawer.style.width = newWidth + 'px';
    });
    document.addEventListener('mouseup', function() {
      if (!dragging) return;
      dragging = false;
      drawer.style.transition = '';
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
    });
  })();

  if (chatInput) chatInput.focus();
</script>

<%- include('partials/footer') %>
