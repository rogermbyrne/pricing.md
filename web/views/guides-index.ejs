<%- include('partials/head', { title, description, path }) %>

<div class="max-w-6xl mx-auto px-6 md:px-10 py-12">
  <h1 class="text-5xl md:text-6xl font-bold tracking-tighter text-neutral-900 dark:text-white">Developer Tool Pricing Guides</h1>
  <p class="text-lg text-neutral-500 mt-3 mb-12">
    <span class="font-mono font-semibold text-neutral-900 dark:text-white"><%= totalVsPages %></span> comparisons · 
    <span class="font-mono font-semibold text-neutral-900 dark:text-white"><%= totalAlternativesPages %></span> alternatives · 
    <span class="font-mono font-semibold text-neutral-900 dark:text-white"><%= totalBestFreePages %></span> best-free guides
  </p>

  <div class="grid grid-cols-1 gap-6 mb-12">
    <a href="/browse" class="block bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-6 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
      <div class="text-sm font-mono uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-2"> Browse All Tools</div>
      <div class="text-2xl font-bold text-neutral-900 dark:text-white mb-2"> <span class="font-mono"><%= totalAlternativesPages %></span> Tools · <span class="font-mono"><%= categoryGuideCounts.length %></span> Categories</div>
      <div class="text-sm text-neutral-500 dark:text-neutral-400"> Explore the complete pricing registry with verified data, free tiers, and switching costs.</div>
    </a>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-6">Best Free Guides by Category</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% for (const cat of categoryGuideCounts.filter(c => c.bestFreePage > 0)) { %>
        <a href="/guides/best-free-<%= cat.slug %>" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
          <div class="flex items-center justify-between mb-3">
            <div class="font-semibold text-neutral-900 dark:text-white">Best Free <%= cat.displayName %></div>
            <div class="text-xs font-mono text-neutral-400 dark:text-neutral-600"><%= cat.vsPages %> comparisons</div>
          </div>
          <div class="text-sm text-neutral-500 dark:text-neutral-400">
            Find free tiers and alternatives in <%= cat.displayName.toLowerCase() %>
          </div>
        </a>
      <% } %>
    </div>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-6">Browse by Category</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% for (const cat of categoryGuideCounts) { %>
        <a href="/browse/<%= cat.slug %>" class="block bg-neutral-50 dark:bg-[#111113] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
          <div class="flex items-center justify-between mb-3">
            <div class="font-semibold text-neutral-900 dark:text-white"><%= cat.displayName %></div>
            <div class="text-xs font-mono text-neutral-400 dark:text-neutral-600"><%= cat.alternativesPages %> tools</div>
          </div>
          <div class="text-sm text-neutral-500 dark:text-neutral-400">
            <%= cat.vsPages %> VS comparisons available
          </div>
        </a>
      <% } %>
    </div>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-6">Popular Comparisons</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <% 
      // Generate a few featured VS comparisons from different categories
      const featuredComparisons = [
        ['vercel', 'railway'],
        ['supabase', 'planetscale'],
        ['auth0-b2c', 'clerk'],
        ['sendgrid', 'resend']
      ];
      %>
      <% for (const [toolA, toolB] of featuredComparisons) { %>
        <% const sorted = [toolA, toolB].sort(); %>
        <a href="/guides/<%= sorted[0] %>-vs-<%= sorted[1] %>" class="block bg-white dark:bg-[#09090b] border border-neutral-200 dark:border-neutral-800 rounded-lg p-5 hover:border-neutral-300 dark:hover:border-neutral-700 transition-all no-underline">
          <div class="flex items-center gap-2 mb-2">
            <span class="font-semibold text-neutral-900 dark:text-white capitalize"><%= toolA.replace(/-/g, ' ') %></span>
            <span class="text-neutral-400">vs</span>
            <span class="font-semibold text-neutral-900 dark:text-white capitalize"><%= toolB.replace(/-/g, ' ') %></span>
          </div>
          <div class="text-sm text-neutral-500 dark:text-neutral-400">Head-to-head pricing comparison</div>
        </a>
      <% } %>
    </div>
  </div>

  <div class="mb-8">
    <h2 class="text-2xl font-bold text-neutral-900 dark:text-white mb-6">Featured Tools</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% for (const tool of lastTools) { %>
        <div class="flex flex-col gap-1">
          <a href="/tool/<%= tool.id %>" class="block text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-white transition-colors no-underline">
            <div class="font-mono text-sm"><%= tool.name %></div>
          </a>
          <a href="/guides/<%= tool.id %>-alternatives" class="text-xs text-neutral-400 hover:text-neutral-600 dark:text-neutral-600 dark:hover:text-neutral-400 transition-colors no-underline">
            alternatives →
          </a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Developer Tool Pricing Guides",
  "description": "Compare developer tool pricing with " + totalVsPages + " head-to-head comparisons",
  "numberOfItems": categoryGuideCounts.length,
  "itemListElement": categoryGuideCounts.map((cat, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": cat.displayName,
    "url": "https://latest.sh/browse/" + cat.slug
  }))
}, null, 2) %>
</script>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://latest.sh/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://latest.sh/guides" }
  ]
}, null, 2) %>
</script>

<%- include('partials/footer') %>
